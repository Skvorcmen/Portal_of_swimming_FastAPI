@router.post("/admin/toggle/{news_id}")
async def admin_news_toggle(
    news_id: int,
    db: AsyncSession = Depends(get_db),
    current_user: User = Depends(get_current_user_optional_cookie),
):
    from app.services.news_service import NewsService
    
    if not current_user or current_user.role != UserRole.ADMIN:
        return RedirectResponse(url="/login", status_code=303)
    
    service = NewsService(db)
    news = await service.get_news(news_id)
    
    if news.is_published:
        await service.update_news(news_id, is_published=False)
    else:
        await service.publish_news(news_id)
    
    return RedirectResponse(url="/news/admin/list", status_code=303)


